# --- Hack Club AI (free LLM inference) -------------------------------------
# Get a key at https://ai.hackclub.com/dashboard (sign in with Hack Club).
HACKCLUB_AI_API_KEY=hc-your-ai-key-here

# Optional: override the model. Defaults to qwen/qwen3-32b. Any model id your
# dashboard lists works (e.g. a Gemini / GPT / Kimi id).
# HACKCLUB_MODEL=qwen/qwen3-32b
# HACKCLUB_SCORING_MODEL=qwen/qwen3-32b

# --- Hack Club Search (free web search for live job/scholarship results) ----
# Get a key at https://search.hackclub.com . Optional but recommended — without
# it, live web search is skipped (jobs still work if Adzuna is configured).
HACKCLUB_SEARCH_API_KEY=

# --- Adzuna (optional: real job listings with canonical apply URLs) ---------
# Free dev keys at https://developer.adzuna.com . When set, jobs use Adzuna
# instead of Hack Club Search.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Set to true before a demo to return cached responses instead of calling the API.
MOCK_MODE=false
